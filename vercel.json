{
  "version": 2,
  "builds": [
    {
      "src": "fonte/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "fonte/static/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "fonte/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "/fonte/static/$1"
    }
  ]
}